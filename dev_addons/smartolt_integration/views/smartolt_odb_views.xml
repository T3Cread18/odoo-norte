<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de formulario para ODBs -->
    <record id="view_smartolt_odb_form" model="ir.ui.view">
        <field name="name">smartolt.odb.form</field>
        <field name="model">smartolt.odb</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_get_odb_details" string="Obtener Detalles" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del ODB"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="odb_id"/>
                            <field name="zone_id"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="location"/>
                            <field name="coordinates"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista de lista para ODBs -->
    <record id="view_smartolt_odb_tree" model="ir.ui.view">
        <field name="name">smartolt.odb.tree</field>
        <field name="model">smartolt.odb</field>
        <field name="arch" type="xml">
                            <tree>
                    <field name="name"/>
                    <field name="odb_id"/>
                    <field name="zone_id"/>
                    <field name="status"/>
                    <field name="location"/>
                    <field name="description"/>
                </tree>
        </field>
    </record>

    <!-- Vista de búsqueda para ODBs -->
    <record id="view_smartolt_odb_search" model="ir.ui.view">
        <field name="name">smartolt.odb.search</field>
        <field name="model">smartolt.odb</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="odb_id"/>
                <field name="zone_id"/>
                <field name="location"/>
                <filter string="Activo" name="active" domain="[('status', '=', 'active')]"/>
                <filter string="Inactivo" name="inactive" domain="[('status', '=', 'inactive')]"/>
                <filter string="Mantenimiento" name="maintenance" domain="[('status', '=', 'maintenance')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Zona" name="group_zone" context="{'group_by': 'zone_id'}"/>
                    <filter string="Ubicación" name="group_location" context="{'group_by': 'location'}"/>
                </group>
            </search>
        </field>
    </record>


</odoo>
