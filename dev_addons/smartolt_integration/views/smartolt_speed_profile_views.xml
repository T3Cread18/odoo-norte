<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de formulario para Perfiles de Velocidad -->
    <record id="view_smartolt_speed_profile_form" model="ir.ui.view">
        <field name="name">smartolt.speed_profile.form</field>
        <field name="model">smartolt.speed_profile</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_get_profile_details" string="Obtener Detalles" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del Perfil"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="profile_id"/>
                            <field name="olt_id"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="download_speed"/>
                            <field name="upload_speed"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="ONUs" name="onus">
                            <field name="onu_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="serial_number"/>
                                    <field name="status"/>
                                    <field name="olt_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista de lista para Perfiles de Velocidad -->
    <record id="view_smartolt_speed_profile_tree" model="ir.ui.view">
        <field name="name">smartolt.speed_profile.tree</field>
        <field name="model">smartolt.speed_profile</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="profile_id"/>
                <field name="olt_id"/>
                <field name="download_speed"/>
                <field name="upload_speed"/>
                <field name="status"/>
                <field name="priority"/>
            </tree>
        </field>
    </record>

    <!-- Vista de búsqueda para Perfiles de Velocidad -->
    <record id="view_smartolt_speed_profile_search" model="ir.ui.view">
        <field name="name">smartolt.speed_profile.search</field>
        <field name="model">smartolt.speed_profile</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="profile_id"/>
                <field name="olt_id"/>
                <filter string="Activo" name="active" domain="[('status', '=', 'active')]"/>
                <filter string="Inactivo" name="inactive" domain="[('status', '=', 'inactive')]"/>
                <filter string="Mantenimiento" name="maintenance" domain="[('status', '=', 'maintenance')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="OLT" name="group_olt" context="{'group_by': 'olt_id'}"/>
                    <filter string="Prioridad" name="group_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    

</odoo>
