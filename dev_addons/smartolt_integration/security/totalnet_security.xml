<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Categoría de seguridad para Totalnet -->
        <record id="module_category_totalnet" model="ir.module.category">
            <field name="name">Totalnet</field>
            <field name="description">Gestión de clientes del sistema Totalnet</field>
            <field name="sequence">20</field>
        </record>

        <!-- Grupo de usuarios para Totalnet -->
        <record id="group_totalnet_user" model="res.groups">
            <field name="name">Usuario Totalnet</field>
            <field name="category_id" ref="module_category_totalnet"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Grupo de administradores para Totalnet -->
        <record id="group_totalnet_manager" model="res.groups">
            <field name="name">Administrador Totalnet</field>
            <field name="category_id" ref="module_category_totalnet"/>
            <field name="implied_ids" eval="[(4, ref('group_totalnet_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo> 