<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de formulario para Wizard de Sincronización por Puerto -->
    <record id="view_smartolt_sync_port_wizard_form" model="ir.ui.view">
        <field name="name">smartolt.sync.port.wizard.form</field>
        <field name="model">smartolt.sync.port.wizard</field>
        <field name="arch" type="xml">
            <form string="Sincronizar ONUs por Puerto">
                <sheet>
                    <group>
                        <group>
                            <field name="olt_id" readonly="1"/>
                            <field name="olt_olt_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="board"/>
                            <field name="port"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_sync_onus_by_port" string="Sincronizar ONUs" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
