<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_atc_zona_list" model="ir.ui.view">
        <field name="name">atc.zona.list</field>
        <field name="model">atc.zona</field>
        <field name="arch" type="xml">
            <list string="Zonas">
                <field name="name"/>
                <field name="code"/>
                <field name="vgt_count" string="N° VGT"/>
            </list>
        </field>
    </record>

    <record id="view_atc_zona_form" model="ir.ui.view">
        <field name="name">atc.zona.form</field>
        <field name="model">atc.zona</field>
        <field name="arch" type="xml">
            <form string="Zona">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <group string="VGT / Proyectos autorizados de esta zona">
                        <field name="vgt_ids" nolabel="1"
                               options="{'no_create': True}">
                            <list string="VGT">
                                <field name="codigo"/>
                                <field name="nombre"/>
                                <field name="estado"/>
                                <field name="municipio"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_atc_zona" model="ir.actions.act_window">
        <field name="name">Zonas</field>
        <field name="res_model">atc.zona</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
