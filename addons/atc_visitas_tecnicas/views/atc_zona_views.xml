<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_atc_zona_list" model="ir.ui.view">
        <field name="name">atc.zona.list</field>
        <field name="model">atc.zona</field>
        <field name="arch" type="xml">
            <list string="Zonas" editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="view_atc_zona_form" model="ir.ui.view">
        <field name="name">atc.zona.form</field>
        <field name="model">atc.zona</field>
        <field name="arch" type="xml">
            <form string="Zona">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_atc_zona" model="ir.actions.act_window">
        <field name="name">Zonas</field>
        <field name="res_model">atc.zona</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
