<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_noc_departamento_list" model="ir.ui.view">
        <field name="name">noc.departamento.list</field>
        <field name="model">noc.departamento</field>
        <field name="arch" type="xml">
            <list string="Departamentos NOC" editable="top">
                <field name="name"/>
                <field name="descripcion"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="view_noc_departamento_form" model="ir.ui.view">
        <field name="name">noc.departamento.form</field>
        <field name="model">noc.departamento</field>
        <field name="arch" type="xml">
            <form string="Departamento NOC">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del departamento..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="color" widget="color_picker"/>
                        <field name="descripcion" placeholder="Descripción del departamento..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_noc_departamento" model="ir.actions.act_window">
        <field name="name">Departamentos NOC</field>
        <field name="res_model">noc.departamento</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
