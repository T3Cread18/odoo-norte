<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_noc_tag_list" model="ir.ui.view">
        <field name="name">noc.tag.list</field>
        <field name="model">noc.tag</field>
        <field name="arch" type="xml">
            <list string="Etiquetas NOC" editable="top">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="view_noc_tag_form" model="ir.ui.view">
        <field name="name">noc.tag.form</field>
        <field name="model">noc.tag</field>
        <field name="arch" type="xml">
            <form string="Etiqueta NOC">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_noc_tag" model="ir.actions.act_window">
        <field name="name">Etiquetas NOC</field>
        <field name="res_model">noc.tag</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
